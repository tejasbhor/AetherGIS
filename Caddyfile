{
    email {$CADDY_EMAIL:admin@example.com}
}

# --- Combined Access (Domain + IP) ---
# This block handles the IP address and any domains pointing to it
{$AETHERGIS_DOMAIN}, http://129.213.145.9, http://localhost, :80 {
    # Frontend
    reverse_proxy aethergis-frontend:80

    # Backend API
    handle_path /api/v1/* {
        reverse_proxy aethergis-backend:8000
    }

    # Security Headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
}
