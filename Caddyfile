{
	email {$CADDY_EMAIL:admin@example.com}
}

# --- Production Domain (HTTPS) ---
{$AETHERGIS_DOMAIN} {
	# Frontend
	reverse_proxy aethergis-frontend:3000

	# Backend API
	handle_path /api/v1/* {
		reverse_proxy aethergis-backend:8000
	}

	# Security Headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
}

# --- Direct IP Access (HTTP) ---
:80 {
	# Frontend
	reverse_proxy aethergis-frontend:3000

	# Backend API
	handle_path /api/v1/* {
		reverse_proxy aethergis-backend:8000
	}
}

# API Backend
{$AETHERGIS_API_DOMAIN:api.aethergis.com} {
	# Root health check
	@health path /api/v1/health
	handle @health {
		reverse_proxy backend:8000
	}

	# All other API requests
	handle {
		reverse_proxy backend:8000
	}

	encode gzip zstd
	
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
	}
}
