# AetherGIS Environment Variables
# Copy this to .env and fill in your values

# NASA GIBS (no auth required for public layers)
NASA_GIBS_BASE_URL=https://gibs.earthdata.nasa.gov/wms/epsg4326/best/wms.cgi
NASA_GIBS_API_KEY=

# ISRO Bhuvan (Phase 2 - leave empty for Phase 1)
BHUVAN_WMS_URL=https://bhuvan-ras2.nrsc.gov.in/bhuvan/wms
BHUVAN_API_KEY=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_PASSWORD=aetherredispass

# Database
DATABASE_URL=sqlite:///backend/data/aethergis.db
POSTGRES_DB=aethergis
POSTGRES_USER=aethergis
POSTGRES_PASSWORD=aethergis

# Routing / Hosting
VITE_API_URL=http://localhost:8000/api/v1
AETHERGIS_DOMAIN=localhost
AETHERGIS_API_DOMAIN=api.localhost
CADDY_EMAIL=admin@example.com

# Storage
DATA_DIR=./backend/data
EXPORTS_DIR=./backend/data/exports
CACHE_DIR=./backend/data/cache
AI_MODELS_DIR=./backend/app/ai_models

# AI Inference
CUDA_DEVICE=cuda
RIFE_MODEL_PATH=./backend/app/ai_models/rife/flownet.pkl
FILM_MODEL_PATH=./backend/app/ai_models/film/film_net_fp32.pt
INFERENCE_TIMEOUT_SECONDS=60

# Accuracy Thresholds
FLOW_CONSISTENCY_THRESHOLD=0.15
FLOW_REJECTION_THRESHOLD=0.40
LARGE_DIFF_THRESHOLD=0.30
MIN_BBOX_AREA=0.01

# Confidence Score Weights
CS_WEIGHT_FLOW=0.40
CS_WEIGHT_MAD=0.35
CS_WEIGHT_GAP=0.25

# WMS Client
WMS_RATE_LIMIT_DELAY=1.0
WMS_MAX_RETRIES=3
WMS_TIMEOUT_SECONDS=30
MAX_FRAMES_PER_SESSION=48
MAX_IMAGE_RESOLUTION=2048
MAX_ACTIVE_RUNS=1
MAX_QUEUED_RUNS=1
RUN_ARTIFACT_TTL_HOURS=72

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
