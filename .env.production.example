# ============================================================
# AetherGIS — Production Environment Configuration
# Instance: Oracle Cloud OCI (Ampere ARM64)
# ============================================================

# ---- Application ----
AETHER_MODE=production
DEBUG=false
APP_NAME="AetherGIS GeoAI Platform"
APP_BASE_URL=https://aethergis.com

# ---- Networking & Domains ----
AETHERGIS_DOMAIN=aethergis.com
AETHERGIS_API_DOMAIN=api.aethergis.com
CADDY_EMAIL=your-email@example.com
# Comma-separated strings (e.g. https://aethergis.com,https://api.aethergis.com)
CORS_ORIGINS=https://aethergis.com,https://api.aethergis.com
VITE_API_URL=https://api.aethergis.com/api/v1

# ---- Database (PostGIS) ----
POSTGRES_DB=aethergis
POSTGRES_USER=aethergis
POSTGRES_PASSWORD=generate_a_strong_password_here
# Note: Use 'postgres' as the hostname in Docker Compose
DATABASE_URL=postgresql+psycopg://aethergis:strong_password_here@postgres:5432/aethergis

# ---- Redis ----
REDIS_PASSWORD=generate_a_strong_redis_password_here
# Note: Use 'redis' as the hostname in Docker Compose
REDIS_URL=redis://:strong_redis_password_here@redis:6379/0
CELERY_BROKER_URL=redis://:strong_redis_password_here@redis:6379/0
CELERY_RESULT_BACKEND=redis://:strong_redis_password_here@redis:6379/1

# ---- Security ----
# Generate with: openssl rand -hex 64
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- AI Engines ----
# Set to 'cpu' if no NVIDIA GPU is available on the OCI instance
TORCH_DEVICE=cpu
# Set to 1 for stability on ARM64
CELERY_WORKER_CONCURRENCY=1

# ---- External Providers ----
# NASA GIBS, ISRO, etc.
NASA_GIBS_API_KEY=optional_key

# ---- Monitoring ----
ENABLE_AUDIT_LOGS=true
LOG_LEVEL=info
